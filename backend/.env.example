# ── 应用基础配置 ──
APP_NAME=NutriMind-Agent
APP_VERSION=0.1.0
DEBUG=true
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ── 数据库配置 (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nutrimind-agent
DB_USER=nutrimind-agent
DB_PASSWORD=nutrimind-agent

# ── Redis 配置 ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── MinIO 配置 ──
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=nutrimind-agent-images
MINIO_SECURE=false

# ── JWT 配置 ──
JWT_SECRET_KEY=liu13568610305
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN=

# ── 大模型配置 ──
OPENAI_API_KEY=sk-ejhpvwtrgzcpkpudikolfzwntfvblkgtqabuhdfznovgudkb
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen3.6-35B-A3B

# ── 食物检测配置 ──
# mock: 仅允许通过 /api/chat/image/mock 注入模拟 YOLO 结果
# yolo: /api/chat/image 使用 data/models/ 下的真实模型
DETECTION_MODE=mock
DEFAULT_DETECTION_MODEL=best.pt
MAX_IMAGE_SIZE_MB=10

# ── LangChain 配置（可选）───────────────────────
# 启用 LangSmith 监控（可选，不需要可设为 false）
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=visagent

# ── CORS 配置 ──
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
